DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=todo_db
SERVER_PORT=50051
APP_ENV=development

LOG_LEVEL=debug
LOG_FORMAT=console

SCHEDULER_ENABLED=true
TODO_OVERDUE_MARKER_CRON=*/5 * * * *
TODO_OVERDUE_MARKER_BATCH_SIZE=500
TODO_OVERDUE_MARKER_MAX_BATCHES=20
TODO_OVERDUE_MARKER_LOCK_KEY=job:mark-overdue-todos
TODO_OVERDUE_MARKER_LOCK_TTL=10m
TODO_OVERDUE_MARKER_BATCH_SLEEP=100ms

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

TODO_BLACKLIST_ENABLED=false
TODO_TITLE_BLACKLIST=spam,troll
