                "exec": [
                  "const jsonData = pm.response.json();",
                  "const token = jsonData.data.login.token;",
                  "if (token) {",
                  "    pm.environment.set(\"access_token\", token);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
